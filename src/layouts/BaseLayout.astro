---
import '../styles/tokens.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.description,
} = Astro.props;

const ogImage = new URL('/images/og-image.png', site.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site.url} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />

    <!-- Two families only: Fraunces (variable serif, opsz + italic) + Hanken Grotesk (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,600&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap"
    />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.62;
    color: var(--color-ink);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  /* Fraunces carries the display voice — optical sizing on, tight leading */
  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    line-height: 1.08;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: var(--color-green);
  }

  /* Visible focus ring on every interactive element */
  :focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Green ring vanishes on the dark contact block — switch to gold there */
  .contact-panel :focus-visible {
    outline-color: var(--color-gold);
  }

  /* Editorial eyebrow label — tracked sans in the warm accent, replaces the old mono motif */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent-strong);
  }

  /* A short accent rule that leads the eyebrow — the section-header tick mark */
  .eyebrow--tick::before {
    content: '';
    width: var(--space-8);
    height: 2px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* Max-content-width container: 1280px, 24px side padding (16px mobile) */
  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  @media (max-width: 639px) {
    main {
      padding: 0 var(--space-4);
    }
  }

  /* Anchored sections shouldn't hide under the sticky nav */
  section[id] {
    scroll-margin-top: 5rem;
  }
</style>
