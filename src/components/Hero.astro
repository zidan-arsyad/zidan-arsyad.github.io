---
import { site } from '../site.config';
import { resumePdf } from '../lib/resume';
---

<section class="hero" id="top" aria-label="Introduction">
  <img
    class="headshot"
    src="/images/headshot.png"
    alt={`Portrait of ${site.name}`}
    width="200"
    height="200"
    loading="eager"
  />
  <div class="intro">
    <h1>{site.name}</h1>
    <p class="tagline">{site.tagline}</p>
    <div class="ctas">
      {
        resumePdf && (
          <a class="cta-primary" href={resumePdf.url} download={resumePdf.downloadName}>
            Download Resume
          </a>
        )
      }
      <a class="cta-secondary" href="#projects">View Projects</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    /* The one entrance moment — nothing else animates on load */
    animation: hero-enter 300ms ease-out both;
  }

  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      animation: none;
    }
  }

  .headshot {
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, var(--text-3xl));
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-ink);
  }

  .tagline {
    margin-top: var(--space-3);
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
  }

  .ctas {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .ctas a {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  .cta-primary {
    background: var(--color-green);
    color: #ffffff;
  }

  .cta-primary:hover {
    background: var(--color-green-strong);
  }

  .cta-secondary {
    color: var(--color-green);
    background: transparent;
  }

  .cta-secondary:hover {
    color: var(--color-green-strong);
    background: var(--color-green-soft);
  }

  @media (max-width: 639px) {
    .hero {
      flex-direction: column;
      text-align: center;
      gap: var(--space-6);
      padding-top: var(--space-8);
      padding-bottom: var(--space-12);
    }

    .ctas {
      justify-content: center;
    }
  }
</style>
