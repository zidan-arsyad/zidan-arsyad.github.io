---
import { site } from '../site.config';
---

<ul class="contact-links">
  <li>
    <a href={`mailto:${site.email}`}>
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1.5" y="3" width="13" height="10" rx="1" />
        <path d="m2 4 6 5 6-5" />
      </svg>
      {site.email}
    </a>
  </li>
  <li>
    <a href={site.github} target="_blank" rel="noopener noreferrer">
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
      GitHub
    </a>
  </li>
  <li>
    <a href={site.linkedin} target="_blank" rel="noopener noreferrer">
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M13.63 13.63h-2.37V9.92c0-.89-.02-2.03-1.24-2.03-1.24 0-1.43.97-1.43 1.96v3.78H6.22V6h2.28v1.04h.03c.32-.6 1.09-1.24 2.25-1.24 2.4 0 2.85 1.58 2.85 3.64v4.19ZM3.54 4.96a1.38 1.38 0 1 1 0-2.75 1.38 1.38 0 0 1 0 2.75Zm1.19 8.67H2.35V6h2.38v7.63ZM14.82 0H1.18C.53 0 0 .52 0 1.15v13.7C0 15.48.53 16 1.18 16h13.64c.65 0 1.18-.52 1.18-1.15V1.15C16 .52 15.47 0 14.82 0Z" />
      </svg>
      LinkedIn
    </a>
  </li>
</ul>

<style>
  /* Rendered inside the dark contact panel (index.astro) — colors target that surface. */
  .contact-links {
    list-style: none;
    margin: var(--space-12) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6) var(--space-3) var(--space-4);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink-invert);
    text-decoration: none;
    border: 1px solid rgba(243, 239, 226, 0.22);
    border-radius: var(--radius-pill);
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  a svg {
    color: var(--color-gold);
    transition: color 150ms ease;
  }

  a:hover {
    color: var(--color-bg-dark);
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  a:hover svg {
    color: var(--color-bg-dark);
  }

  @media (max-width: 639px) {
    .contact-links {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
