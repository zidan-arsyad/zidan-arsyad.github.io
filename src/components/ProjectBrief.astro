---
import type { CollectionEntry } from 'astro:content';

// The signature element: each project entry is laid out like a one-page
// briefing document (design.md Section 3), not a generic card.
interface Props {
  project: CollectionEntry<'projects'>;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
const { title, role, org, date, summary, details, stack, links } = project.data;

const dateLabel = date
  .toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  .toUpperCase();
---

<article class:list={['brief', { featured }]}>
  <div class="eyebrow-row">
    {featured && <span class="eyebrow featured-label">Featured</span>}
    <span class="eyebrow date">{dateLabel}</span>
  </div>

  <h3>{title}</h3>
  <p class="byline">{role} · {org}</p>

  <p class="summary">{summary}</p>

  {
    stack.length > 0 && (
      <ul class="tags" aria-label="Tech stack">
        {stack.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )
  }

  {
    (details || links.length > 0) && (
      <div class="footer-row">
        {details && (
          <details>
            <summary>
              <span class="chevron" aria-hidden="true">▸</span> Details
            </summary>
            <dl class="brief-body">
              <dt class="eyebrow">Background</dt>
              <dd>{details.background}</dd>
              <dt class="eyebrow">Approach</dt>
              <dd>{details.approach}</dd>
              <dt class="eyebrow">Outcome</dt>
              <dd>{details.outcome}</dd>
            </dl>
          </details>
        )}
        {links.length > 0 && (
          <a
            class="project-link"
            href={links[0].url}
            target="_blank"
            rel="noopener noreferrer"
          >
            View project ↗
          </a>
        )}
      </div>
    )
  }
</article>

<style>
  .brief {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    padding: var(--space-6);
  }

  .brief:hover {
    border-color: var(--color-border-strong);
  }

  .brief.featured {
    border-color: var(--color-border-strong);
    padding: var(--space-8);
  }

  .eyebrow-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .featured-label {
    color: var(--color-green);
  }

  .date {
    margin-left: auto;
  }

  h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .featured h3 {
    font-size: var(--text-2xl);
  }

  .byline {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .summary {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .tags {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tags li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-green-strong);
    background: var(--color-green-soft);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  /* Two separate controls, side by side, never nested:
     expand (state) on the left, redirect (navigation) on the right.
     The link is absolutely positioned so the expanded brief body
     can span the full card width beneath both controls. */
  .footer-row {
    position: relative;
    margin-top: var(--space-6);
    min-height: 2.25rem; /* keeps the row's height when only the link renders */
  }

  details {
    width: 100%;
  }

  summary {
    display: inline-block;
    cursor: pointer;
    list-style: none;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ink);
    padding: var(--space-2) 0; /* tap target */
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary:hover {
    color: var(--color-green);
  }

  .chevron {
    display: inline-block;
    transition: transform 200ms ease;
  }

  details[open] .chevron {
    transform: rotate(90deg);
  }

  .brief-body {
    margin: var(--space-4) 0 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-3) var(--space-6);
    animation: brief-open 200ms ease-out;
  }

  @keyframes brief-open {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chevron {
      transition: none;
    }

    .brief-body {
      animation: none;
    }
  }

  .brief-body dd {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .project-link {
    position: absolute;
    top: 0;
    right: 0;
    padding: var(--space-2) 0; /* tap target */
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-green);
    text-decoration: none;
    white-space: nowrap;
  }

  .project-link:hover {
    color: var(--color-green-strong);
    text-decoration: underline;
  }

  @media (max-width: 639px) {
    .brief.featured {
      padding: var(--space-6);
    }

    .brief-body {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }

    .brief-body dd {
      margin-bottom: var(--space-3);
    }
  }
</style>
